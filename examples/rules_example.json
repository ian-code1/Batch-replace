{
  "rules": [
    {
      "pattern": "old-domain.com",
      "replace": "new-domain.com",
      "regex": false
    },
    {
      "pattern": "\\b\\d{3}-\\d{4}\\b",
      "replace": "[PHONE_NUMBER]",
      "regex": true
    },
    {
      "pattern": "localhost:3000",
      "replace": "${API_URL}",
      "regex": false
    },
    {
      "pattern": "password\\s*=\\s*['\"](.*?)['\"]",
      "replace": "password=\"[REDACTED]\"",
      "regex": true
    }
  ]
}